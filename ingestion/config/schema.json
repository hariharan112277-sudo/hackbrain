{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IobRawTelemetrySchema",
  "type": "object",
  "required": [
    "timestamp",
    "asset_id",
    "machine_id",
    "sensor_id",
    "topic",
    "measurement",
    "value",
    "unit",
    "quality",
    "sequence_number",
    "gateway_id",
    "site_id",
    "plant_id",
    "line_id"
  ],
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "asset_id": { "type": "string", "minLength": 5 },
    "machine_id": { "type": "string", "minLength": 5 },
    "sensor_id": { "type": "string", "minLength": 5 },
    "topic": { "type": "string" },
    "measurement": { "type": "string" },
    "value": { "type": "number" },
    "unit": { "type": "string" },
    "quality": { "type": "string" },
    "sequence_number": { "type": "integer", "minimum": 0 },
    "gateway_id": { "type": "string" },
    "site_id": { "type": "string" },
    "plant_id": { "type": "string" },
    "line_id": { "type": "string" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}

# Development defaults are intentionally safe for local use.
IOB_ENV_MODE=development
IOB_POSTGRES_DSN=sqlite:///./iob_development.db
IOB_JWT_SECRET_KEY=development-only-secret-key-change-before-deploying
IOB_MQTT_BROKER_HOST=127.0.0.1
IOB_AI_GATEWAY_KEY=
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_FORMAT=json
LOG_LEVEL=INFO

# Production: set IOB_ENV_MODE=production, a random >=256-bit key,
# a PostgreSQL DSN, explicit CORS_ORIGINS, and real service credentials.

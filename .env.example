# =============================================================================
# Enterprise Backend Core - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.

# --- Project Identity ---
PROJECT_NAME="Enterprise Backend Core"
VERSION="1.0.0"
API_PREFIX="/api/v1"

# --- Environment Strategy ---
# Options: local, development, staging, production
ENVIRONMENT=local
# Repository safety gate. Production must set ENV=production and this flag false.
ENV=development
USE_STUB_REPOSITORIES=true
DEBUG=true

# --- Security ---
# CHANGE THIS in staging/production! Must be >= 32 characters.
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_JWT_SECRET_KEY_abc123
# Required and non-blank when ENV or ENVIRONMENT is production.
MQTT_PASSWORD=
ALLOWED_HOSTS=["*"]

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
JSON_LOGS=true

# --- Database (Track A — Database Layer) ---
# PostgreSQL connection string consumed by app/database.py via app.config settings.
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/iob

# --- IOB Integration Layer ---
IOB_MQTT_URL=mqtt://localhost:1883
IOB_TOPIC_PREFIX=industrial/iob
DEFAULT_PAGE_LIMIT=100
MAX_HISTORICAL_WINDOW_DAYS=30
ENABLE_REALTIME_STREAMING=true
ENFORCE_OPC_QUALITY_CHECKS=true
